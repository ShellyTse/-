# 智者圆桌 · 环境变量配置
# 复制此文件为 .env.local 用于本地开发（不要提交到 Git）
# 在 Vercel Dashboard → Settings → Environment Variables 里填写

# ── 必填：至少填一个模型的 Key ──────────────────────────
# Anthropic Claude（https://console.anthropic.com）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# DeepSeek（https://platform.deepseek.com）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxx

# ── 访问控制 ────────────────────────────────────────────
# 访问密码（留空则不需要密码）
ACCESS_PASSWORD=your-secret-password

# 每个 IP 每天最多请求次数（默认 30）
# 注意：每次"召集圆桌"会调用9次，30次约等于3轮完整体验
MAX_REQUESTS_PER_IP=30
